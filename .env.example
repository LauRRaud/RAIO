# RA•IO Payload CMS configuration
#
# Local example:
# DATABASE_URL=postgres://raio:change-me@127.0.0.1:5432/raio
#
# Generate a strong secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATABASE_URL=
PAYLOAD_SECRET=

# --- Maksekeskus / MakeCommerce payment gateway ---
#
# Avalik saidi aadress, mille pealt ehitatakse return- ja notification-URL-id.
# Maksekeskus kutsub notification-URL-i väljastpoolt, seega arenduses peab see
# olema avalik tunneli aadress (nt ngrok), MITTE localhost.
SITE_URL=

# "live" = päris maksed. Kõik muu (või tühi) = testkeskkond.
MAKSEKESKUS_MODE=test

# Shop ID ja Secret key Maksekeskuse portaalist (Pood -> API). Test-režiimis
# võib jätta tühjaks — siis kasutatakse Maksekeskuse avalikke testvõtmeid.
MAKSEKESKUS_SHOP_ID=
MAKSEKESKUS_SECRET_KEY=
